{
  "name": "@hive-memory/client",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript client SDK for the Hive memory API",
  "author": "John Carter",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  },
  "homepage": "https://app.hive-memory.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/warlordofmars/hive.git"
  }
}
